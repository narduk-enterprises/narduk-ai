{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "narduk-ai",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "narduk-ai-db",
      "database_id": "2176c867-da11-4328-a79a-852fa713ca9e"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "narduk-ai-media"
    }
  ],
  "routes": [
    {
      "pattern": "narduk-ai.nard.uk",
      "custom_domain": true
    }
  ],
  "triggers": {
    "crons": [
      "* * * * *"
    ]
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "ee260bee73a84615b28617b5751d910f",
      "preview_id": "b073fa0870f948af9f20c1513e7f421f"
    }
  ]
}
